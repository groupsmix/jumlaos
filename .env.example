# Copy to `.env` and fill in. Never commit real secrets.

# --- Core ---
JUMLAOS_ENV=dev                      # dev | staging | prod
JUMLAOS_LOG_LEVEL=INFO
JUMLAOS_SECRET_KEY=change-me-to-a-long-random-string-at-least-32-chars
JUMLAOS_ALLOWED_ORIGINS=http://localhost:3000

# --- Auth / OTP ---
OTP_TRANSPORT=log                    # log | whatsapp | sms (log only in dev)
# SMS_PROVIDER=none                  # none | twilio
# SMS_ACCOUNT_SID=
# SMS_AUTH_TOKEN=
# SMS_FROM_NUMBER=

# --- Database ---
DATABASE_URL=postgresql+asyncpg://jumlaos:jumlaos@localhost:5432/jumlaos
# In prod: must include sslmode=verify-full (F22)
DATABASE_URL_SYNC=postgresql://jumlaos:jumlaos@localhost:5432/jumlaos
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=10

# --- Redis ---
REDIS_URL=redis://localhost:6379/0

# --- Request limits (F25) ---
# JUMLAOS_MAX_REQUEST_BYTES=262144   # 256 KB default
# JUMLAOS_MAX_WEBHOOK_BYTES=16777216 # 16 MB default

# --- Object storage (Cloudflare R2, S3-compatible) ---
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=jumlaos-dev
R2_ENDPOINT=https://<account>.r2.cloudflarestorage.com

# --- WhatsApp Cloud API (Meta) ---
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_BUSINESS_ACCOUNT_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_WEBHOOK_VERIFY_TOKEN=
WHATSAPP_APP_SECRET=                 # used to verify X-Hub-Signature-256

# --- LLM / STT / OCR ---
OPENAI_API_KEY=
GEMINI_API_KEY=
ANTHROPIC_API_KEY=

# --- Billing (CMI) ---
CMI_MERCHANT_ID=
CMI_STORE_KEY=
CMI_CALLBACK_HMAC_SECRET=

# --- Observability ---
SENTRY_DSN=
LOGTAIL_TOKEN=
POSTHOG_PROJECT_KEY=
POSTHOG_HOST=https://eu.posthog.com

# --- Email (Resend) ---
RESEND_API_KEY=
RESEND_FROM="JumlaOS <no-reply@jumlaos.ma>"
